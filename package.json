{
  "name": "ytmusic-pwa-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "dev": "npm run dev -w backend -w frontend --parallel"
  },
  "dependencies": {
    "youtube-po-token-generator": "^0.6.0"
  },
  "allowScripts": {
    "esbuild@0.21.5": true,
    "prisma@7.8.0": true,
    "@prisma/engines@7.8.0": true,
    "better-sqlite3@12.11.1": true
  }
}
